{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE"
  },
  "deploy": {
    "startCommand": "gunicorn -c gunicorn.conf.py app:app",
    "numReplicas": 1,
    "restartPolicyType": "ALWAYS",
    "env": {
      "PORT": "8080",
      "PYTHONUNBUFFERED": "1"
    }
  }
}
